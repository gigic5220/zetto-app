  "schemas": {
    "LoginRequest": {
      "type": "object",
      "description": "로그인 요청",
      "properties": {
        "member_id": {
          "type": "string",
          "description": "회원 ID",
          "maxLength": 50,
          "minLength": 0
        },
        "password": {
          "type": "string",
          "description": "비밀번호",
          "maxLength": 50,
          "minLength": 0
        },
        "device_uuid": {
          "type": "string",
          "description": "디바이스 UUID (없으면 서버에서 생성)",
          "maxLength": 100,
          "minLength": 0
        }
      },
      "required": [
        "member_id",
        "password"
      ]
    },
    "LoginResponse": {
      "type": "object",
      "description": "로그인 응답",
      "properties": {
        "device_uuid": {
          "type": "string",
          "description": "디바이스 UUID"
        },
        "refresh_token": {
          "type": "string",
          "description": "리프레시 토큰"
        },
        "expiration_time": {
          "type": "integer",
          "format": "int64",
          "description": "만료 시각 (Unix timestamp)"
        }
      }
    },
    "AdotLearningTokenRequest": {
      "type": "object",
      "description": "에이닷러닝 액세스 토큰 발급 요청",
      "properties": {
        "memberId": {
          "type": "string",
          "description": "회원 ID",
          "maxLength": 30,
          "minLength": 0
        },
        "memberRole": {
          "type": "string",
          "description": "회원 역할",
          "example": "student",
          "minLength": 1,
          "pattern": "^(student|teacher|staff)$"
        }
      },
      "required": [
        "memberId",
        "memberRole"
      ]
    },
    "AccessTokenResponse": {
      "type": "object",
      "description": "액세스 토큰 발급 응답",
      "properties": {
        "token": {
          "type": "string",
          "description": "JWT 액세스 토큰"
        }
      }
    },
    "AccessTokenRequest": {
      "type": "object",
      "description": "액세스 토큰 발급 요청",
      "properties": {
        "device_uuid": {
          "type": "string",
          "description": "디바이스 UUID",
          "maxLength": 100,
          "minLength": 0
        },
        "refresh_token": {
          "type": "string",
          "description": "리프레시 토큰",
          "minLength": 1
        }
      },
      "required": [
        "device_uuid",
        "refresh_token"
      ]
    }
